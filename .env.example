# Server
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/screenetic

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# S3 Storage
S3_BUCKET=screenetic-reports
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=http://localhost:9000  # MinIO for local dev

# Email
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=SG.xxxxx
EMAIL_FROM=noreply@screenetic.io
EMAIL_FROM_NAME=Screenetic

# Admin
ADMIN_API_KEY=your-admin-key-here
